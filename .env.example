# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SECRET_KEY=eyJ...

# App URL (Stripe redirects, auth callback; optional in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (subscription: monthly + yearly, e.g. 2 months free on yearly)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# Vercel Cron auth (required in production for /api/cron/process-invoice-queue)
CRON_SECRET=your-random-secret

# Encrypt stored credentials (Moxie API key, Billingo/Számlázz.hu). 64-char hex.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
